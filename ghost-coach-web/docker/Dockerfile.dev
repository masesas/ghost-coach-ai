# syntax=docker/dockerfile:1.7
# Dev image — Vite dev server with HMR.
# Source is bind-mounted at runtime; this image only ships Node + cached node_modules.

FROM node:22-alpine

WORKDIR /workspace

# Cache layer: install deps based only on lockfile + package.json
COPY package.json package-lock.json* ./
RUN npm install --no-fund --no-audit

# Pre-create the bind-mount target so Vite can scan it even before host mount applies
RUN mkdir -p /workspace/src

EXPOSE 5173

ENV HOST=0.0.0.0 \
    CHOKIDAR_USEPOLLING=false \
    NODE_ENV=development

# Use `npm run dev` so users can extend via package.json scripts.
# `--host 0.0.0.0` is also already set in vite.config.ts but kept here for clarity.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
